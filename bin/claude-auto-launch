#!/bin/bash
# claude-auto-launch - Start services, wait for health, open browser tabs
# Usage: claude-auto launch

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$SCRIPT_DIR/lib/helpers.sh"
source "$SCRIPT_DIR/lib/config.sh" 2>/dev/null || true

# Load user config and convert to v2.x format for backward compatibility
load_config 2>/dev/null || true
load_project_config 2>/dev/null || true

# Ensure pnpm is in PATH (added during installation)
export PNPM_HOME="/Users/pwilliamson/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

echo "🌐 Claude Auto Launch"
echo ""

# Start services if configured
start_services_if_configured

# Give services time to start
sleep 3

# Wait for all services to be healthy (30s timeout)
if wait_for_all_services 30; then
    echo ""
    echo "Opening browser tabs..."
    launch_browser_tabs
    echo "✓ Browser tabs opened"
else
    echo ""
    echo "⚠️  Some services not healthy. Open anyway? (y/N)"
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
        launch_browser_tabs
        echo "✓ Browser tabs opened (with warnings)"
    else
        echo "Aborted. Start services with: claude-auto"
    fi
fi

display_timestamp "claude-auto launch"
