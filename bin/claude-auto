#!/bin/bash
# claude-auto v3.6 - Config-driven Claude Code launcher
# v3.4: Correct permission format (no parentheses for allow-all)
# v3.5: Project args (jsa|devops|wa|llm) + help command
# v3.6: Added nextlane project + real `list` command implementation

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/helpers.sh" 2>/dev/null || true


# Handle help
if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    echo ""
    echo "claude-auto v3.6 — Config-Driven Claude Code Launcher"
    echo ""
    echo "USAGE"
    echo "  claude-auto [project]          Launch Claude Code in the specified project directory"
    echo "  claude-auto [project] launch   Start project services and open browser tabs"
    echo "  claude-auto launch             Start default project services (from config)"
    echo "  claude-auto list               Show all available project names"
    echo "  claude-auto help               Show this help"
    echo ""
    echo "PROJECTS"
    echo "  devops    ~/Dropbox/ALOMA/claude-code/"
    echo "            Loads: all MCPs (Kubernetes, Azure, Cloudflare, GitHub, Keycloak, n8n)"
    echo "            Use for: AKS infra, Flux GitOps, CRDB, NATS, Azure operations"
    echo ""
    echo "  jsa       ~/Dropbox/ALOMA/claude-code/job-search-agent/"
    echo "            Loads: Attio, Gmail, Granola, Notion, GitHub, ALOMA MCPs only"
    echo "            Use for: outreach pipeline, contact research, email scanning"
    echo ""
    echo "  wa        ~/Dropbox/ALOMA/claude-code/apps/workflow-automation/"
    echo "            Loads: ALOMA, n8n, GitHub, Notion, Attio, Gmail (ALOMA account)"
    echo "            Use for: ALOMA workflow studio, n8n automation development"
    echo ""
    echo "  llm       ~/Dropbox/ALOMA/claude-code/apps/llm-council/"
    echo "            Loads: GitHub, Notion only"
    echo "            Use for: LLM Council prompt evaluation and testing"
    echo ""
    echo "  alomastep ~/Dropbox/ALOMA/claude-code/aloma-step-writing/"
    echo "            Loads: project .mcp.json (if present)"
    echo "            Use for: ALOMA step-writing reference docs and examples"
    echo ""
    echo "  nextlane  ~/Dropbox/ALOMA/claude-code/nextlane/"
    echo "            Loads: project .mcp.json (if present)"
    echo "            Use for: Nextlane interim CPO engagement — board deck, OEM strategy, AI vision"
    echo ""
    echo "  adev      ~/Dropbox/ALOMA/claude-code-dev/"
    echo "            Loads: project .mcp.json (if present)"
    echo "            Use for: ALOMA Platform Track 2 dev (AEH builds, MCP, connectors, apps)"
    echo ""
    echo "  (no arg)  Uses CLAUDE_AUTO_WORKDIR from ~/.claude-auto.conf"
    echo "            Default project as configured"
    echo ""
    echo "MCP LOADING"
    echo "  Each project loads only its own .mcp.json — Kubernetes/Cloudflare/Keycloak"
    echo "  do NOT load for jsa, wa, or llm sessions."
    echo "  DevOps session loads all MCPs (use for infra work only)."
    echo ""
    echo "SERVICES (launch subcommand)"
    echo "  claude-auto launch        Start services defined in ~/.claude-auto.conf"
    echo "  claude-auto jsa launch    Start JSA services (dashboard, agents) + open browser"
    echo ""
    echo "CONFIG"
    echo "  Config file:  ~/.claude-auto.conf"
    echo "  Log file:     /tmp/claude-auto-startup.log"
    echo "  Tail log:     tail -f /tmp/claude-auto-startup.log"
    echo ""
    exit 0
fi

# Handle 'list' subcommand — print all registered projects and exit
if [ "${1:-}" = "list" ]; then
    echo ""
    echo "claude-auto — registered projects:"
    echo ""
    printf "  %-10s %s\n" "devops"    "$HOME/Dropbox/ALOMA/claude-code/"
    printf "  %-10s %s\n" "jsa"       "$HOME/Dropbox/ALOMA/claude-code/job-search-agent/"
    printf "  %-10s %s\n" "wa"        "$HOME/Dropbox/ALOMA/claude-code/apps/workflow-automation/"
    printf "  %-10s %s\n" "llm"       "$HOME/Dropbox/ALOMA/claude-code/apps/llm-council/"
    printf "  %-10s %s\n" "alomastep" "$HOME/Dropbox/ALOMA/claude-code/aloma-step-writing/"
    printf "  %-10s %s\n" "nextlane"  "$HOME/Dropbox/ALOMA/claude-code/nextlane/"
    printf "  %-10s %s\n" "adev"      "$HOME/Dropbox/ALOMA/claude-code-dev/"
    echo ""
    exit 0
fi

# Handle 'launch' subcommand
# Supports: claude-auto launch  OR  claude-auto <project> launch
if [ "${1:-}" = "launch" ] || [ "${2:-}" = "launch" ]; then
    exec "$SCRIPT_DIR/bin/claude-auto-launch"
fi
STARTUP_LOG="/tmp/claude-auto-startup.log"

print_banner() {
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  claude-auto v3.5 - Config-Driven Claude Code Launcher       ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
}

ensure_claude_permissions() {
    local settings_dir="$CLAUDE_AUTO_WORKDIR/.claude"
    local settings_file="$settings_dir/settings.json"
    mkdir -p "$settings_dir"
    if [[ -f "$settings_file" ]] && grep -q '"Bash"' "$settings_file" 2>/dev/null && ! grep -q '"Bash(\*)"' "$settings_file" 2>/dev/null; then
        echo "✅ .claude/settings.json already configured" >> "$STARTUP_LOG"
        return
    fi
    cat > "$settings_file" << 'EOF'
{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "mcp__desktop-commander"
    ]
  }
}
EOF
    echo "✅ .claude/settings.json created with permissions" >> "$STARTUP_LOG"
}

start_services_if_configured() {
    [[ -z "${CLAUDE_AUTO_SERVICES+x}" ]] && return  # Variable not set
    [[ ${#CLAUDE_AUTO_SERVICES[@]} -eq 0 ]] && return
    echo "=== Service Status ===" >> "$STARTUP_LOG"
    for service_def in "${CLAUDE_AUTO_SERVICES[@]}"; do
        IFS=':' read -r name port start_cmd health_path <<< "$service_def"
        if lsof -i :"$port" >/dev/null 2>&1; then
            echo "✅ $name (port $port) - running" >> "$STARTUP_LOG"
        else
            echo "🔄 Starting $name on port $port..." >> "$STARTUP_LOG"
            (cd "$CLAUDE_AUTO_WORKDIR" && eval "$start_cmd" >> "$STARTUP_LOG" 2>&1 &)
        fi
    done
}

open_browser_tabs() {
    [[ -z "${CLAUDE_AUTO_BROWSER_URLS+x}" ]] && return  # Variable not set
    [[ ${#CLAUDE_AUTO_BROWSER_URLS[@]} -eq 0 ]] && return
    for url in "${CLAUDE_AUTO_BROWSER_URLS[@]}"; do open "$url" 2>/dev/null || true; done
}

quick_git_status() {
    [[ -z "${CLAUDE_AUTO_REPOS:-}" ]] && return  # Variable not set
    echo "=== Quick Git Status ===" >> "$STARTUP_LOG"
    for repo in $CLAUDE_AUTO_REPOS; do
        [[ -d "$CLAUDE_AUTO_WORKDIR/$repo/.git" ]] || continue
        cd "$CLAUDE_AUTO_WORKDIR/$repo"
        changes=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
        unpushed=$(git log --oneline @{u}..HEAD 2>/dev/null | wc -l | tr -d ' ')
        [[ "$changes" -gt 0 || "$unpushed" -gt 0 ]] && echo "⚠️  $repo: $changes uncommitted, $unpushed unpushed" >> "$STARTUP_LOG"
    done
    cd "$CLAUDE_AUTO_WORKDIR"
}

main() {
    print_banner
    load_config

    # Project override: claude-auto [project]
    # Overrides CLAUDE_AUTO_WORKDIR from config for this session only
    local project="${1:-}"
    case "$project" in
        devops)  CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code" ;;
        jsa)     CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code/job-search-agent" ;;
        wa)      CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code/apps/workflow-automation" ;;
        llm)     CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code/apps/llm-council" ;;
        alomastep) CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code/aloma-step-writing" ;;
        nextlane) CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code/nextlane" ;;
        adev)    CLAUDE_AUTO_WORKDIR="$HOME/Dropbox/ALOMA/claude-code-dev" ;;
        ""|launch|help|--help|-h|list) ;;  # handled above or use config default
        *) echo "⚠️  Unknown project: '$project'"; echo "Run 'claude-auto help' for valid options"; exit 1 ;;
    esac
    if [[ -n "$project" && ! "$project" =~ ^(launch|help|--help|-h|list)$ ]]; then
        echo "🎯 Project: $project → $CLAUDE_AUTO_WORKDIR"
    fi

    echo "=== claude-auto startup $(date) ===" > "$STARTUP_LOG"
    cd "$CLAUDE_AUTO_WORKDIR"
    echo "📂 Working directory: $CLAUDE_AUTO_WORKDIR"
    echo "📋 Status: tail -f $STARTUP_LOG"
    echo ""
    ensure_claude_permissions
    (sleep 1; start_services_if_configured) &
    (sleep 2; quick_git_status) &
    echo "🚀 Launching Claude Code..."
    exec claude
}

main "$@"

# Display completion timestamp
display_timestamp "claude-auto"
