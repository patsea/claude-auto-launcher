#!/usr/bin/env bash
#
# claude-auto-boot-catchup
# Runs missed cron jobs after system boot
#
# Version: 1.0
# Created: 2026-01-18

set -euo pipefail

LOG_FILE="$HOME/.claude-auto/logs/boot-catchup.log"
LAST_RUN_FILE="$HOME/.claude-auto/.last-boot-catchup"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

# Ensure log directory exists
mkdir -p "$HOME/.claude-auto/logs"

log "=========================================="
log "Boot Catch-Up Started"
log "=========================================="

# Get system boot time
BOOT_TIME=$(sysctl -n kern.boottime | awk '{print $4}' | sed 's/,//')
BOOT_DATE=$(date -r "$BOOT_TIME" '+%Y-%m-%d %H:%M:%S')
log "System booted at: $BOOT_DATE"

# Check if we've already run since this boot
if [ -f "$LAST_RUN_FILE" ]; then
    LAST_RUN=$(cat "$LAST_RUN_FILE")
    if [ "$LAST_RUN" -ge "$BOOT_TIME" ]; then
        log "Already ran since boot. Exiting."
        exit 0
    fi
fi

# Check if any cron jobs were missed: "today's slot has passed AND the job hasn't run today".
# Times below are LOCAL — the user crontab runs in system TZ, so we match.
# Slot hours derived from the live crontab at execution time (re-derive on crontab change):
#   audit            : 08:00 local   (0 8 * * *)
#   model-tasks      : 08:15 local   (15 8 * * *)
#   weekly-research  : 08:30 local   (30 8 * * *)  — daily, NOT Monday-only
#   backup           : 08:45 local   (45 8 * * *)  — cleanup is COUPLED (runs iff backup catchup fires)
# 'readme' has no crontab entry (handled by LaunchAgent com.claude-auto.readme) — no catchup gate.

HEARTBEAT_FILE="$HOME/Dropbox/ALOMA/claude-code/infra/state/claude-auto-heartbeats.json"
LOCAL_TODAY="$(date +%Y-%m-%d)"
LOCAL_MIDNIGHT_EPOCH="$(date -j -f '%Y-%m-%d %H:%M:%S' "${LOCAL_TODAY} 00:00:00" '+%s')"
NOW_EPOCH="$(date +%s)"

# Helper: did the named heartbeat job run since today's local midnight?
ran_today_heartbeat() {
    local key="$1" ep
    ep=$(jq -r ".\"${key}\".epoch // 0" "$HEARTBEAT_FILE" 2>/dev/null || echo 0)
    [ "$ep" -ge "$LOCAL_MIDNIGHT_EPOCH" ]
}

# Helper: has today's HH:MM local slot already passed?
slot_passed() {
    local hhmm="$1" slot_epoch
    slot_epoch=$(date -j -f '%Y-%m-%d %H:%M:%S' "${LOCAL_TODAY} ${hhmm}:00" '+%s')
    [ "$NOW_EPOCH" -ge "$slot_epoch" ]
}

MISSED_JOBS=()

# audit — dated log artefact is the definitive ran-today signal.
if slot_passed '08:00' && [ ! -f "$HOME/.claude-auto/logs/audit-${LOCAL_TODAY}.log" ]; then
    MISSED_JOBS+=("audit")
fi

# model-tasks — heartbeat key 'aloma-model-tasks'.
if slot_passed '08:15' && ! ran_today_heartbeat 'aloma-model-tasks'; then
    MISSED_JOBS+=("model-tasks")
fi

# weekly-research — heartbeat key 'weekly-research'. Daily in crontab; no Monday-only constraint.
if slot_passed '08:30' && ! ran_today_heartbeat 'weekly-research'; then
    MISSED_JOBS+=("weekly-research")
fi

# backup — heartbeat key 'aloma-backup'. cleanup is COUPLED to backup catchup per
# Patrick decision 2026-06-01 (no independent heartbeat key or dated artefact for cleanup).
if slot_passed '08:45' && ! ran_today_heartbeat 'aloma-backup'; then
    MISSED_JOBS+=("backup" "cleanup")
fi

# Exit if no missed jobs
if [ ${#MISSED_JOBS[@]} -eq 0 ]; then
    log "No missed cron jobs. All scheduled tasks will run normally."
    echo "$BOOT_TIME" > "$LAST_RUN_FILE"
    exit 0
fi

log "Detected ${#MISSED_JOBS[@]} missed job(s): ${MISSED_JOBS[*]}"
log "Running catch-up tasks..."

# Run missed jobs
for job in "${MISSED_JOBS[@]}"; do
    case "$job" in
        backup)
            log "Running: ALOMA backup"
            /Users/pwilliamson/Dropbox/ALOMA/claude-code/aloma-backup.sh >> /Users/pwilliamson/Dropbox/ALOMA/claude-code/aloma-backup.log 2>&1 &
            ;;
        cleanup)
            log "Running: Instruction file cleanup"
            "$HOME/.claude-auto/bin/claude-auto-cleanup" >> "$LOG_FILE" 2>&1
            ;;
        model-tasks)
            log "Running: Model task generation"
            /opt/homebrew/bin/bash /Users/pwilliamson/Dropbox/ALOMA/claude-code/aloma-model-tasks.sh >> /Users/pwilliamson/Dropbox/ALOMA/claude-code/aloma-backup/model-tasks-cron.log 2>&1
            ;;
        audit)
            log "Running: System audit"
            "$HOME/.claude-auto/bin/claude-auto-audit" --no-color > "$HOME/.claude-auto/logs/audit-$(date +%Y-%m-%d).log" 2>&1
            ;;
        weekly-research)
            log "Running: Weekly AI research (Monday only)"
            cd /Users/pwilliamson/Dropbox/ALOMA/claude-code/workflow-automation && npx tsx scripts/weekly-research.ts >> /Users/pwilliamson/Dropbox/ALOMA/claude-code/workflow-automation/logs/research.log 2>&1 &
            ;;
    esac
done

# Record this run
echo "$BOOT_TIME" > "$LAST_RUN_FILE"

log "=========================================="
log "Boot Catch-Up Complete"
log "Note: Backup may still be running in background"
log "=========================================="

exit 0
